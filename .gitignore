# Create .gitignore file
New-Item -Path ".gitignore" -ItemType File -Force

# Add content to .gitignore
@"
# Virtual Environment
venv/
env/
ENV/
env.bak/
venv.bak/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# pyenv
.python-version

# uv
uv.lock
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Project specific
*.log
*.pid
*.seed
*.pid.lock
.env
.venv
.qodo
# Testing
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Gradio
gradio_cached_examples/
"@ | Out-File -FilePath .gitignore -Encoding utf8